{
  "name": "cascada-engine",
  "version": "0.4.0",
  "description": "The parallel-first scripting & templating engine with transparent async support and automatic, implicit concurrency.",
  "type": "module",
  "license": "BSD-2-Clause",
  "author": "Angel Popov<geleto@gmail.com>",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "cascada-precompile": "dist/bin/precompile"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist/**"
  ],
  "homepage": "https://github.com/geleto/cascada",
  "dependencies": {
    "a-sync-waterfall": "^1.0.1",
    "asap": "^2.0.6",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.4",
    "@babel/plugin-transform-classes": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/register": "^7.27.1",
    "@babel/traverse": "^7.27.4",
    "@eslint/js": "^9.28.0",
    "@istanbuljs/nyc-config-babel": "^3.0.0",
    "babel-loader": "^10.0.0",
    "babel-plugin-istanbul": "^7.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "connect": "^3.7.0",
    "core-js": "^3.43.0",
    "cpy-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "docsify-cli": "^4.4.4",
    "dummy-pkg": "file:tests/test-node-pkgs/dummy-pkg",
    "eslint": "^9.28.0",
    "eslint-plugin-mocha": "^11.1.0",
    "expect.js": "*",
    "express": "5.x",
    "fs-extra": "^11.3.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.2.0",
    "he": "^1.2.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "madge": "^8.0.0",
    "mocha": "^11.1.0",
    "module-alias": "^2.2.3",
    "ncp": "^2.0.0",
    "node-libs-browser": "^2.2.1",
    "nyc": "^17.1.0",
    "playwright": "^1.52.0",
    "serve-static": "^2.2.0",
    "supertest": "*",
    "terser-webpack-plugin": "^5.3.14",
    "tiny-chalk": "^3.0.2",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "peerDependencies": {
    "chokidar": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "chokidar": {
      "optional": true
    }
  },
  "resolutions": {
    "globals": "11.12.0"
  },
  "_moduleAliases": {
    "babel-register": "@babel/register"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "node scripts/dev-install.js",
    "mocha": "mocha --check-leaks -R spec \"tests/*.js\" \"tests/pasync/**/*.js\" \"tests/poison/**/*.js\"",
    "lint": "eslint src scripts tests",
    "prepare": "npm run build",
    "clean": "node --input-type=module -e \"import {rmSync} from 'node:fs'; rmSync('dist', {recursive: true, force: true})\"",
    "build:bundle": "node scripts/bundle.js",
    "build:types": "cpy src/index.d.ts dist/types/ --flat",
    "build:docs": "cpy docs/cascada/script.md README.md dist/docs/ --flat",
    "build": "npm run clean && npm run lint && npm run build:esm && npm run build:types && cpy bin/**/* dist/bin/ && npm run build:docs",
    "build:esm": "node scripts/build-esm.mjs",
    "test:quick": "npm run mocha",
    "test:esm": "npm run mocha",
    "test:node": "cross-env NODE_ENV=test nyc --reporter=html --reporter=text --reporter=json mocha --check-leaks --reporter ./scripts/lib/node-stats-reporter tests \"tests/pasync/**/*.js\" \"tests/poison/**/*.js\"",
    "test:browser": "cross-env NODE_ENV=test node scripts/bundle.js && node scripts/run-browser-tests.js",
    "test:pasync": "cross-env NODE_ENV=test nyc --reporter=html --reporter=text mocha --check-leaks \"tests/pasync/**/*.js\" \"tests/poison/**/*.js\"",
    "test": "node scripts/run-all-tests.js",
    "mocha:single": "mocha --check-leaks -R spec",
    "docs:build": "node scripts/docs-build.js",
    "docs:serve": "npm run docs:build && docsify serve generated-docs/script",
    "docs:publish": "npm run docs:build && gh-pages -d generated-docs/script -r https://github.com/geleto/cascada-script.git -b gh-pages",
    "check:cycles": "madge --extensions js --circular src"
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-babel",
    "all": true,
    "include": [
      "src/**/*.js"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "sourceMap": true,
    "instrument": false
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geleto/cascada.git"
  },
  "keywords": [
    "template",
    "script",
    "templating",
    "scripting",
    "template engine",
    "script engine",
    "scripting engine",
    "templating engine",
    "async",
    "parallel",
    "concurrency",
    "concurrent",
    "parallel-first"
  ],
  "bugs": {
    "url": "https://github.com/geleto/cascada/issues"
  }
}
