{
  "name": "cascada-engine",
  "version": "0.4.0",
  "description": "The parallel-first scripting & templating engine with transparent async support and automatic, implicit concurrency.",
  "type": "module",
  "license": "BSD-2-Clause",
  "author": "Angel Popov<geleto@gmail.com>",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "cascada-precompile": "dist/bin/precompile"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./precompiled": {
      "import": "./dist/precompiled/index.js",
      "types": "./dist/types/precompiled/index.d.ts"
    }
  },
  "files": [
    "dist/**"
  ],
  "homepage": "https://github.com/geleto/cascada",
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@eslint/js": "^9.28.0",
    "babel-plugin-istanbul": "^7.0.0",
    "c8": "^10.1.3",
    "cross-env": "^7.0.3",
    "docsify-cli": "^4.4.4",
    "dummy-pkg": "file:tests/test-node-pkgs/dummy-pkg",
    "eslint": "^9.28.0",
    "eslint-plugin-mocha": "^11.1.0",
    "expect.js": "*",
    "express": "5.x",
    "gh-pages": "^6.3.0",
    "globals": "^16.2.0",
    "he": "^1.2.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "madge": "^8.0.0",
    "mocha": "^11.1.0",
    "playwright": "^1.52.0",
    "supertest": "*"
  },
  "resolutions": {
    "globals": "11.12.0"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "node scripts/dev-install.js",
    "mocha": "node scripts/run-node-tests.js",
    "lint": "eslint src scripts tests",
    "prepare": "npm run build",
    "clean": "node --input-type=module -e \"import {rmSync} from 'node:fs'; rmSync('dist', {recursive: true, force: true})\"",
    "build:types": "node scripts/copy-build-assets.js types",
    "build:docs": "node scripts/copy-build-assets.js docs",
    "build": "npm run clean && npm run lint && npm run build:esm && npm run build:types && node scripts/copy-build-assets.js bin && npm run build:docs",
    "build:esm": "node scripts/build-esm.mjs",
    "test:quick": "npm run mocha",
    "test:esm": "npm run mocha",
    "test:node": "cross-env NODE_ENV=test c8 --include \"src/**/*.js\" --reporter=html --reporter=text --reporter=json node scripts/run-node-tests.js",
    "test:browser": "cross-env NODE_ENV=test node scripts/run-browser-tests.js",
    "test:pasync": "cross-env NODE_ENV=test c8 --include \"src/**/*.js\" --reporter=html --reporter=text node scripts/run-node-tests.js tests/pasync tests/poison",
    "test": "node scripts/run-all-tests.js",
    "mocha:single": "mocha --check-leaks -R spec",
    "docs:build": "node scripts/docs-build.js",
    "docs:serve": "npm run docs:build && docsify serve generated-docs/script",
    "docs:publish": "npm run docs:build && gh-pages -d generated-docs/script -r https://github.com/geleto/cascada-script.git -b gh-pages",
    "check:cycles": "madge --extensions js --circular src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geleto/cascada.git"
  },
  "keywords": [
    "template",
    "script",
    "templating",
    "scripting",
    "template engine",
    "script engine",
    "scripting engine",
    "templating engine",
    "async",
    "parallel",
    "concurrency",
    "concurrent",
    "parallel-first"
  ],
  "bugs": {
    "url": "https://github.com/geleto/cascada/issues"
  }
}
