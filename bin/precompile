#!/usr/bin/env node
import {program} from 'commander';
import fs from 'fs';
import path from 'path';
import {fileURLToPath, pathToFileURL} from 'url';

const binDir = path.dirname(fileURLToPath(import.meta.url));
const packageRoot = path.resolve(binDir, '..');

const moduleRoots = [
  packageRoot,
  path.join(packageRoot, 'dist')
];

function createModuleSet(root) {
  return {
    precompile: path.join(root, 'precompile.js'),
    environment: path.join(root, 'environment', 'environment.js'),
    lib: path.join(root, 'lib.js')
  };
}

const moduleSet = moduleRoots.map(createModuleSet).find((set) =>
  fs.existsSync(set.precompile) &&
  fs.existsSync(set.environment) &&
  fs.existsSync(set.lib)
);

if (!moduleSet) {
  console.error('Build output not found: required CLI files are missing. Run `npm run build` before using bin/precompile.');
  process.exit(1);
}

const precompileModule = await import(pathToFileURL(moduleSet.precompile));
const environmentModule = await import(pathToFileURL(moduleSet.environment));
const libModule = await import(pathToFileURL(moduleSet.lib));

const precompile = precompileModule.precompile || precompileModule.default?.precompile;
const Environment = environmentModule.Environment || environmentModule.default?.Environment;
const lib = libModule;
let cmdpath = null;

program
  .storeOptionsAsProperties(false);

program
  .name('precompile')
  .usage('[-f|--force] [-a|--filters <filters>] [-n|--name <name>] [-i|--include <regex>] [-x|--exclude <regex>] [-w|--wrapper <wrapper>] <path>')
  .arguments('<path>')
  .helpOption('-h, --help', 'display help for command')
  .option('-f, --force', 'Force compilation to continue on error')
  .option('-a, --filters <filters>', 'Give the compiler a comma-delimited list of asynchronous filters, required for correctly generating code')
  .option('-n, --name <name>', 'Specify the template name when compiling a single file')
  .option('-i, --include <regex>', 'Include a file or folder which match the regex but would otherwise be excluded. You can use this flag multiple times', concat, ['\\.html$', '\\.jinja$'])
  .option('-x, --exclude <regex>', 'Exclude a file or folder which match the regex but would otherwise be included. You can use this flag multiple times', concat, [])
  .option('-w, --wrapper <wrapper>', 'Load a external plugin to change the output format of the precompiled templates (for example, "-w custom" will load a module named "nunjucks-custom")')
  .action(function (templatePath) {
    cmdpath = templatePath;
  })
  .parse(process.argv);

function concat(value, previous) {
  return previous.concat(value);
}

if (cmdpath == null) {
  program.outputHelp();
  console.error('\nerror: no path given');
  process.exit(1);
}

const env = new Environment([]);
const opts = program.opts();

lib.each([].concat(opts.filters).join(',').split(','), function (name) {
  env.addFilter(name.trim(), function () {}, true);
});

if (opts.wrapper) {
  const wrapperModule = await import(`nunjucks-${opts.wrapper}`);
  opts.wrapper = wrapperModule.wrapper || wrapperModule.default?.wrapper;
}

console.log(precompile(cmdpath, {
  env: env,
  force: opts.force,
  name: opts.name,
  wrapper: opts.wrapper,
  include: [].concat(opts.include),
  exclude: [].concat(opts.exclude)
}));
